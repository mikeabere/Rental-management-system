PORT=6000
MONGO_URL = mongodb://localhost:27017/Rentify

JWT_EXPIRES_IN=1d
NODE_ENV=development

# JWT
JWT_SECRET=secret
JWT_EXPIRES_IN=7d

# M-PESA DARAJA (Sandbox first!)
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://your-ngrok-url/mpesa/callback

# JENGA API (Finserve)
JENGA_API_KEY=your_jenga_api_key
JENGA_CLIENT_ID=your_client_id
JENGA_PRIVATE_KEY_PATH=./jenga-private-key.pem   # Put your RSA private key here
JENGA_BASE_URL=https://uat.finserve.africa   # Change to https://api.finserve.africa for live

# Other
FRONTEND_URL=http://localhost:3000
